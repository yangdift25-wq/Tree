#include"Heap.h"

//建堆
void test()
{
  HP php;
  HPInit(&php);
  int a[]={1,2,34,3,563,6243,34};
  int n=sizeof(a)/sizeof(size[0]);
  for(int i=0;i<n;i++)
  {
    HPPush(&php,a[i]);
  }
HeapSort(php.a,php.size-1);
}

//排序
void HeapSort(HPDataType* a,int n)
{
  int end=n;
  while(end>0)
  {
    Swap(&a[0],&a[end]);
    end--;
    AdjustDown(a,end,0);
  }
  }
